# FreeAIchat-2api 配置文件模板 (v1.5)

# --- 第一步：设置你的专属安全密钥 (可选，但强烈推荐) ---
API_MASTER_KEY=sk-freeai-your-super-secret-key

# --- 第二步：获取你的“抓包四件套” ---
# 这是连接到 FreeAIchat 服务的核心凭证。请严格按照 README.md 中的抓包教程操作。

# 1. COOKIE:
#    在 admin-ajax.php 请求的“标头(Headers)”中，找到 "cookie:" 字段，复制【全部】内容。
#    推荐使用 COOKIE_B64，避免 Docker Compose 展开 Cookie 里的 '$变量'。
#    生成方式: printf '%s' '完整 Cookie 字符串' | base64 -w 0
COOKIE_B64="在这里粘贴 Base64 编码后的完整 Cookie 字符串"
#    兼容旧配置，也可以直接使用 COOKIE，但 Cookie 中的 '$' 必须转义为 '$$'。
# COOKIE="在这里粘贴你的完整 Cookie 字符串"

# 2. AJAX_NONCE:
#    在 admin-ajax.php 请求的“载荷(Payload)”中，找到 "_ajax_nonce" 的值。
AJAX_NONCE="在这里粘贴你的 _ajax_nonce"

# 3. SESSION_ID:
#    在 action=aipkit_frontend_chat_stream 请求的 URL 中，找到 "session_id" 的值。
SESSION_ID="在这里粘贴你的 session_id"

# 4. POST_ID:
#    同样在 action=aipkit_frontend_chat_stream 请求的 URL 中，找到 "post_id" 的值。
POST_ID="6"

# --- 第三步：配置上游代理 (可选) ---
# 如果本机代理可用，可以启用下面这一行。也支持使用 HTTP_PROXY / HTTPS_PROXY。
# 本机直接运行服务，或 Docker 使用 host network 时:
# UPSTREAM_PROXY=http://127.0.0.1:7890

# --- 第四步：配置 Nginx 端口 (可选) ---
# Docker 使用 host network 时，会直接监听宿主机的这个端口。
NGINX_PORT=4001
